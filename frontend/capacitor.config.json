{
  "appId": "com.estia.agent",
  "appName": "Estia",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "loggingBehavior": "debug",
  "ios": {
    "contentInset": "never",
    "preferredContentMode": "mobile",
    "limitsNavigationsToAppBoundDomains": false,
    "scheme": "Estia",
    "allowsLinkPreview": false,
    "overrideUserAgent": "Estia/1.0 (iOS)",
    "backgroundColor": "#0d0f14"
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": true,
    "backgroundColor": "#0d0f14"
  },
  "server": {
    "hostname": "estia.local",
    "androidScheme": "https",
    "iosScheme": "capacitor"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#0d0f14",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true,
      "useDialog": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0d0f14",
      "overlaysWebView": false
    },
    "Keyboard": {
      "resize": "native",
      "resizeOnFullScreen": true,
      "style": "DARK"
    },
    "Haptics": {},
    "Preferences": {
      "group": "EstiaPrefs"
    },
    "Geolocation": {}
  }
}
