{
  "name": "estia",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.0",
  "engines": {
    "node": "20.20.2",
    "npm": ">=11"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "test": "npm run test:unit && npm run test:frontend && npm run test:integration",
    "test:unit": "vitest run --project=unit",
    "test:unit:watch": "vitest --project=unit",
    "test:frontend": "vitest run --project=frontend --project=unit-frontend",
    "test:frontend:watch": "vitest --project=frontend --project=unit-frontend",
    "test:integration": "vitest run --project=integration",
    "test:integration:watch": "vitest --project=integration",
    "test:e2e": "playwright test",
    "test:e2e:critical": "playwright test --grep @critical",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@faker-js/faker": "^9.0.3",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "happy-dom": "^20.9.0",
    "jsdom": "^25.0.1",
    "msw": "^2.13.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9",
    "vitest-axe": "^0.1.0"
  }
}
