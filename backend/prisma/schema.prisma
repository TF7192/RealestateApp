// Estia real-estate CRM — database schema
// Designed to hold everything from the Hebrew docs + PRD + the frontend mock data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  AGENT
  CUSTOMER
  // Sprint 1 / MLS parity — Task A1. An OWNER is an agency owner who
  // sees every agent in their `Office`. Defaults to AGENT-scoped
  // visibility when no office is attached.
  OWNER
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum AssetClass {
  RESIDENTIAL
  COMMERCIAL
}

enum PropertyCategory {
  SALE
  RENT
}

enum PropertyStatus {
  ACTIVE
  PAUSED
  SOLD
  RENTED
  ARCHIVED
  // Sprint 1 / MLS parity — Task J9. Nadlan's `StatusID` exposes three
  // extra life-cycle values that we need for conversion parity. UI
  // labels: אקטואלי (ACTIVE) · לא אקטואלי (INACTIVE) · מוקפא (PAUSED)
  // · נמכר (SOLD) · הושכר (RENTED) · מבוטל (CANCELLED) · עיסקה
  // (IN_DEAL). ARCHIVED stays for the existing soft-delete UX.
  INACTIVE
  CANCELLED
  IN_DEAL
}

// Sprint 1 / MLS parity — Task J9. Pipeline stage is *orthogonal* to
// status: a property can be `ACTIVE` (listed) at many different stages
// of its relationship with the office (watching / in-progress / signed
// non-exclusive / signed exclusive / exclusivity ended / refused
// brokerage / removed). Hebrew UI labels per the Nadlan form:
//   WATCHING             → במעקב
//   PRE_ACQUISITION      → טרום גיוס
//   IN_PROGRESS          → נכס בטיפול              (default for legacy rows)
//   SIGNED_NON_EXCLUSIVE → נכס חתום בהסכמה
//   SIGNED_EXCLUSIVE     → נכס חתום בלעדי
//   EXCLUSIVITY_ENDED    → בלעדיות הסתיימה
//   REFUSED_BROKERAGE    → לא מעוניין בתיווך
//   REMOVED              → הסר מנכסים בטיפול
enum PropertyStage {
  WATCHING
  PRE_ACQUISITION
  IN_PROGRESS
  SIGNED_NON_EXCLUSIVE
  SIGNED_EXCLUSIVE
  EXCLUSIVITY_ENDED
  REFUSED_BROKERAGE
  REMOVED
}

// Sprint 1 / MLS parity — Task J9. Owner-side seriousness rating (how
// serious the *seller* is, not the buyer lead). Nadlan's `SeriousID`
// Hebrew labels: לא (NONE) · די (SORT_OF) · בינוני (MEDIUM) · מאד (VERY).
enum Seriousness {
  NONE
  SORT_OF
  MEDIUM
  VERY
}

// Sprint 3 / MLS parity — Task J5. Building / unit condition, distinct
// from the free-text `renovated` hint which stays for legacy rows.
enum PropertyCondition {
  NEW // חדש מקבלן
  AS_NEW // חדש
  RENOVATED // משופץ
  PRESERVED // שמור
  NEEDS_RENOVATION // דורש שיפוץ
  NEEDS_TLC // זקוק לחידוש
  RAW // שלד / מעטפת
}

// Sprint 1 / MLS parity — Task D1. Standalone reminder ("תזכורת").
// Orthogonal to LeadMeeting (which is a calendar-synced meeting with a
// lead). A reminder can float (no anchor) or attach to a lead /
// property / customer for quick navigation.
enum ReminderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum LeadStatus {
  HOT
  WARM
  COLD
}

enum LeadInterestType {
  PRIVATE
  COMMERCIAL
}

enum LeadLookingFor {
  BUY
  RENT
}

// Sprint 1 / MLS parity — Task K2. Customer-facing life-cycle status
// (Nadlan `CustomerStatusID`). Distinct from LeadStatus (HOT/WARM/COLD),
// which stays as the thermal temperature rating. Hebrew labels:
//   ACTIVE    → אקטואלי
//   INACTIVE  → לא אקטואלי
//   CANCELLED → מבוטל
//   PAUSED    → מוקפא
//   IN_DEAL   → עיסקה
//   BOUGHT    → קנה
//   RENTED    → שכר
enum CustomerStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  PAUSED
  IN_DEAL
  BOUGHT
  RENTED
}

// Sprint 1 / MLS parity — Task K2. Purpose of search, multi-select.
// Nadlan `PurposeList` Hebrew labels: השקעה · מגורים · מסחרי · קומבינציה.
enum CustomerPurpose {
  INVESTMENT
  RESIDENCE
  COMMERCIAL
  COMBINATION
}

// Sprint 2 / MLS parity — Task L1. Quick-lead status ("סטטוס ליד") —
// Nadlan's richer `LeadStatusID`. Orthogonal to `LeadStatus`
// (HOT/WARM/COLD = thermal) and `CustomerStatus` (customer lifecycle).
// Hebrew labels:
//   NEW                      → חדש
//   INTENT_TO_CALL           → בכוונת התקשרות
//   CONVERTED                → הומר
//   DISQUALIFIED             → נפסל
//   NOT_INTERESTED           → לא מעוניין
//   IN_PROGRESS              → בתהליך
//   CONVERTED_NO_OPPORTUNITY → הומר, אין הזדמנות
//   DELETED                  → נמחק
//   ARCHIVED                 → ארכיון
enum QuickLeadStatus {
  NEW
  INTENT_TO_CALL
  CONVERTED
  DISQUALIFIED
  NOT_INTERESTED
  IN_PROGRESS
  CONVERTED_NO_OPPORTUNITY
  DELETED
  ARCHIVED
}

enum DealStatus {
  NEGOTIATING
  WAITING_MORTGAGE
  PENDING_CONTRACT
  SIGNED
  FELL_THROUGH
}

enum ConversationStatus {
  OPEN
  ARCHIVED
}

model Conversation {
  id            String             @id @default(cuid())
  // Every customer/agent has at most one conversation with support.
  userId        String             @unique
  user          User               @relation("UserConversations", fields: [userId], references: [id], onDelete: Cascade)
  status        ConversationStatus @default(OPEN)
  createdAt     DateTime           @default(now())
  lastMessageAt DateTime           @default(now())
  messages      Message[]

  @@index([status, lastMessageAt])
}

// Message bodies are immutable once sent — readAt is the only mutable
// field. `senderRole` disambiguates 'admin' from the user (role might
// be AGENT but still sending, so we explicitly track which side).
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  senderRole     String // 'user' | 'admin'
  body           String
  createdAt      DateTime     @default(now())
  readAt         DateTime?

  @@index([conversationId, createdAt])
}

enum MarketingReminderFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

// ─── Offices ───────────────────────────────────────────────────────────────
// Sprint 1 / MLS parity — Task A1. A real-estate office groups multiple
// agents under one `OWNER`-role user. `officeId` on User is nullable to
// keep the existing single-agent flow working; owners see rows where
// `agentId IN (office members)`, agents still scope to their own.
model Office {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members User[]
  // Sprint 1 / MLS parity — Task A1 fill-in. Email-based invites for
  // users who aren't yet registered. Rows auto-resolve on signup/login.
  invites OfficeInvite[]
}

// Sprint 1 / MLS parity — Task A1 fill-in. An invitation by email into
// an office. Rows are upserted on (officeId, email) so re-inviting the
// same address updates the existing row. When a user logs in or signs
// up with a matching email, auth.ts attaches them to the office and
// marks the invite accepted.
model OfficeInvite {
  id           String    @id @default(cuid())
  officeId     String
  office       Office    @relation(fields: [officeId], references: [id], onDelete: Cascade)
  email        String
  invitedById  String
  invitedBy    User      @relation("OfficeInvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedAt   DateTime?
  acceptedById String?
  acceptedBy   User?     @relation("OfficeInvitesAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([officeId, email])
  @@index([email])
}

// ─── Users ─────────────────────────────────────────────────────────────────
model User {
  id                    String       @id @default(cuid())
  email                 String       @unique
  passwordHash          String?
  role                  UserRole
  provider              AuthProvider @default(EMAIL)
  googleId              String?      @unique
  displayName           String
  // Public, SEO-friendly identifier — used in /agents/<slug> URLs.
  slug                  String?      @unique
  phone                 String?
  avatarUrl             String?
  // ── Onboarding tutorial ────────────────────────────────────────
  // Tracks whether the agent has completed (or skipped) the first-run
  // tour, and which platform they first logged in on — we only show
  // the tour on that same platform so it doesn't re-fire after a
  // device switch.
  hasCompletedTutorial  Boolean      @default(false)
  firstLoginPlatform    String? // 'web' | 'ios' | 'android'
  // 7.1 — Google Calendar OAuth tokens. Populated by a consent flow
  // that's separate from (but layered on top of) the existing Google
  // login — agents who logged in with email can still connect their
  // Calendar. Access token expires ~1h; we keep the refresh token to
  // mint new ones server-side without user re-consent.
  googleAccessToken     String?
  googleRefreshToken    String?
  googleTokenExpiresAt  DateTime?
  googleCalendarEnabled Boolean      @default(false)

  // Sprint 1 / MLS parity — Task A1. Office membership. Null for the
  // legacy solo-agent flow; populated once an OWNER invites an agent
  // into their office. Deleting an office doesn't delete the users —
  // it just detaches them.
  officeId String?
  office   Office? @relation(fields: [officeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Agent-specific profile
  agentProfile AgentProfile?

  // Customer-specific profile (one-to-one with a Lead row once imported)
  customerProfile CustomerProfile?

  // Audit trail
  sessions             Session[]
  properties           Property[]         @relation("AgentProperties")
  owners               Owner[]            @relation("AgentOwners")
  leads                Lead[]             @relation("AgentLeads")
  deals                Deal[]             @relation("AgentDeals")
  files                UploadedFile[]
  transfersSent        PropertyTransfer[] @relation("TransferFrom")
  transfersReceived    PropertyTransfer[] @relation("TransferTo")
  templates            MessageTemplate[]
  conversations        Conversation[]     @relation("UserConversations")
  sentMessages         Message[]          @relation("SentMessages")
  prospects            Prospect[]
  leadMeetings         LeadMeeting[]      @relation("AgentMeetings")
  tags                 Tag[]              @relation("AgentTags")
  // Sprint 1 / MLS parity — Task J9. Properties for which this user is
  // the primary assignee. Separate from `AgentProperties` because a row
  // can be owned by one agent and assigned to another inside the office.
  primaryForProperties Property[]         @relation("PrimaryAgent")
  // Sprint 1 / MLS parity — Task D1.
  reminders            Reminder[]         @relation("AgentReminders")
  reminderAnchors      Reminder[]         @relation("ReminderCustomer")
  // Sprint 1 / MLS parity — Task K2.
  leadAssignments      LeadAgent[]        @relation("LeadAssignments")
  // Sprint 5 / MLS parity — Task J10.
  propertyAssignments  PropertyAssignee[] @relation("PropertyAssigneeUser")
  // Sprint 6 / MLS parity — Task F1.
  adverts              Advert[]           @relation("AgentAdverts")
  // Sprint 7 / MLS parity — Tasks B3, B4.
  savedSearches        SavedSearch[]      @relation("AgentSavedSearches")
  favorites            Favorite[]         @relation("AgentFavorites")
  // Sprint 1 / MLS parity — Task A1 fill-in. Office invites sent by
  // this user (as OWNER) and accepted by this user (on signup/login).
  officeInvitesSent     OfficeInvite[]    @relation("OfficeInvitesSent")
  officeInvitesAccepted OfficeInvite[]    @relation("OfficeInvitesAccepted")

  @@index([role])
  @@index([officeId])
}

model AgentProfile {
  userId  String  @id
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency  String?
  title   String?
  license String?
  bio     String?
  // Formal intake-form header fields.
  personalId         String? // ת.ז. of the agent, printed on the order header
  businessAddress    String? // e.g. "אלון 18א', נס ציונה"
  // Agent's own brokerage-intake legal text — rendered on the public
  // prospect-sign form. Agents paste the exact copy they use on paper
  // (or let product supply a sensible default). HTML so multi-paragraph
  // formatting survives; we sanitize on render.
  brokerageTermsHtml String?
}

model CustomerProfile {
  userId String  @id
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Connects a customer-login to their lead record if one exists
  leadId String? @unique
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// Sliding-window quota for Yad2 agency-wide imports — each Playwright
// crawl is expensive (60-120s + bot-tax against Yad2's WAF), so each
// agent gets a soft cap of 3 attempts per rolling 60 minutes. Rows are
// pruned when a new attempt is recorded; the table is therefore capped
// at ~3 rows per agent at steady state.
model Yad2ImportAttempt {
  id          String   @id @default(cuid())
  agentId     String
  attemptedAt DateTime @default(now())

  @@index([agentId, attemptedAt])
}

// ─── Domain ────────────────────────────────────────────────────────────────
model Property {
  id                         String                     @id @default(cuid())
  agentId                    String
  agent                      User                       @relation("AgentProperties", fields: [agentId], references: [id])
  // Per-agent SEO slug — used in /agents/<agent>/<property> URLs.
  slug                       String?
  assetClass                 AssetClass
  category                   PropertyCategory
  status                     PropertyStatus             @default(ACTIVE)
  type                       String // דירה, משרד, חנות, etc.
  street                     String
  city                       String
  lat                        Float?
  lng                        Float?
  // Task 3 — validated structured address. `placeId` is the Photon / OSM id
  // (e.g. "W123", "R456"); `formattedAddress` is the full Hebrew line from
  // the Places provider. Nullable so legacy rows keep rendering from the
  // free-text `street` + `city` until they're re-validated.
  placeId                    String?
  formattedAddress           String?
  // ── Property owner (the seller / landlord) ─────────────────────────────
  // `propertyOwnerId` references the new Owner table — the canonical record.
  // The legacy inline `owner` / `ownerPhone` / `ownerEmail` columns remain
  // as a denormalized copy so older code keeps working during the rollout;
  // they're auto-synced from the Owner row at write-time.
  propertyOwnerId            String?
  propertyOwner              Owner?                     @relation(fields: [propertyOwnerId], references: [id], onDelete: SetNull)
  owner                      String
  ownerPhone                 String
  ownerEmail                 String?
  exclusiveStart             DateTime?
  exclusiveEnd               DateTime?
  marketingPrice             Int
  closingPrice               Int?
  offer                      Int?
  sqm                        Int
  sqmArnona                  Int?
  sqmTabu                    Int?
  sqmGross                   Int? // Commercial: gross area
  sqmNet                     Int? // Commercial: net usable area
  rooms                      Float?
  floor                      Int?
  totalFloors                Int?
  // ── Elevator ────────────────────────────────────────────────
  elevator                   Boolean                    @default(false)
  elevatorCount              Int? // How many elevators in the building
  shabbatElevator            Boolean                    @default(false)
  // ────────────────────────────────────────────────────────────
  renovated                  String?
  buildState                 String? // Commercial: shell (מעטפת) / finished (גמר)
  vacancyDate                String?
  vacancyFlexible            Boolean                    @default(false)
  // ── Parking ─────────────────────────────────────────────────
  parking                    Boolean                    @default(false)
  parkingType                String? // "tabu" | "nearby" | "private"
  parkingCount               Int?
  parkingCovered             Boolean                    @default(false)
  parkingCoupled             Boolean                    @default(false) // צמודות
  parkingTandem              Boolean                    @default(false) // עוקבות
  parkingEvCharger           Boolean                    @default(false)
  nearbyParking              Boolean                    @default(false) // Commercial: public parking nearby
  // ── Storage ─────────────────────────────────────────────────
  storage                    Boolean                    @default(false)
  storageLocation            String? // "attached" | "basement"
  storageSize                Int?
  // ────────────────────────────────────────────────────────────
  balconySize                Int                        @default(0)
  // 1.1 — sub-option surfaced in the form only when balconySize > 0.
  // Free-form string (not enum) so product can add values without a
  // migration; UI today offers "SUNNY" (שמש) / "COVERED" (מקורה).
  balconyType                String?
  airDirections              String?
  ac                         Boolean                    @default(false)
  safeRoom                   Boolean                    @default(false) // ממ״ד (in-unit)
  floorShelter               Boolean                    @default(false) // מרחב מוגן קומתי (floor-level)
  shelter                    Boolean                    @default(false) // מקלט (building-level)
  buildingAge                Int?
  sector                     String?
  notes                      String?
  // ── Registry / fees ─────────────────────────────────────────
  neighborhood               String?
  gush                       String? // Israeli land registry block
  helka                      String? // Israeli land registry parcel
  arnonaAmount               Int? // Monthly arnona fee (shekel)
  buildingCommittee          Int? // Monthly ועד בית fee
  // ── Commercial-specific amenities ──────────────────────────
  kitchenette                Boolean                    @default(false)
  meetingRoom                Boolean                    @default(false)
  workstations               Int?
  lobbySecurity              Boolean                    @default(false)
  // ── Exclusivity agreement ──────────────────────────────────
  exclusivityAgreementUrl    String? // S3 key or URL to signed PDF
  // 1.3 — explicit "on-market" date, independent of row createdAt so
  // re-listings and import backfills can show the right "days on market".
  // NULL means the property was never marketed (draft). Falls back to
  // createdAt in the UI for legacy rows.
  marketingStartDate         DateTime?
  // 3.2 — commercial-only zone tag (e.g. "איזור תעשיה"). Residential
  // rows keep NULL. Free-form string to avoid another migration when
  // product adds more zones.
  commercialZone             String?
  lastContact                DateTime?
  lastContactNotes           String?
  marketingReminderFrequency MarketingReminderFrequency @default(WEEKLY)

  // Sprint 3 / MLS parity — Tasks J4–J7. Richer property attributes to
  // reach Nadlan One parity on the listing form. All additive + nullable/
  // defaulted so legacy rows stay valid.
  condition      PropertyCondition?
  heatingTypes   String[]           @default([])
  halfRooms      Int?
  masterBedroom  Boolean            @default(false)
  bathrooms      Int?
  toilets        Int?
  furnished      Boolean            @default(false)
  petFriendly    Boolean            @default(false)
  doormenService Boolean            @default(false)
  gym            Boolean            @default(false)
  pool           Boolean            @default(false)
  gatedCommunity Boolean            @default(false)
  accessibility  Boolean            @default(false)
  utilityRoom    Boolean            @default(false)
  listingSource  String? // e.g. "yad2" | "onmap" | "facebook" | "referral" | "self"

  // Sprint 1 / MLS parity — Task J9. Pipeline stage (see PropertyStage
  // comment), commission %, primary assignee, exclusivity expiry, and
  // seller-side seriousness. `status` stays the life-cycle flag; the
  // two axes are orthogonal.
  stage              PropertyStage? @default(IN_PROGRESS)
  agentCommissionPct Float?
  // Primary assignee ("סוכן מטפל"). Defaults to the row's `agentId`;
  // set explicitly when the office owner reassigns without transferring
  // ownership. Nullable so legacy rows stay clean.
  primaryAgentId     String?
  primaryAgent       User?          @relation("PrimaryAgent", fields: [primaryAgentId], references: [id], onDelete: SetNull)
  exclusivityExpire  DateTime?
  sellerSeriousness  Seriousness?
  brokerNotes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images           PropertyImage[]
  marketingActions MarketingAction[]
  viewings         PropertyViewing[]
  inquiries        PropertyInquiry[]
  videos           PropertyVideo[]
  deal             Deal?
  agreements       Agreement[]
  transfers        PropertyTransfer[]
  prospects        Prospect[]
  reminders        Reminder[]
  assignees        PropertyAssignee[]
  adverts          Advert[]

  @@unique([agentId, slug])
  @@index([agentId])
  @@index([city])
  @@index([assetClass, category, status])
  @@index([propertyOwnerId])
}

// ────────────────────────────────────────────────────────────────────────────
// Owner — a real person who owns one or more of an agent's listed properties.
//
// Distinct from `Lead` (which represents a CUSTOMER — a prospective buyer or
// renter looking through the agent's listings). One physical human can be
// represented by both an Owner and a Lead row if they wear both hats; that's
// expected and tracked separately so the agent's "ספר בעלים" stays clean.
// ────────────────────────────────────────────────────────────────────────────
model Owner {
  id           String   @id @default(cuid())
  agentId      String
  agent        User     @relation("AgentOwners", fields: [agentId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  email        String?
  notes        String?
  // Relationship hint, e.g. "בעל יחיד", "ירושה", "חברה". Optional copy.
  relationship String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  properties Property[]
  phones     OwnerPhone[]

  @@index([agentId])
  @@index([phone])
}

/// J8 multi-phone. One row per phone number; the legacy `Owner.phone`
/// column above is kept as the denormalized "primary" for back-compat.
model OwnerPhone {
  id        String   @id @default(cuid())
  ownerId   String
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  phone     String
  kind      String   @default("primary") // primary|secondary|spouse|work|fax|other
  label     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

enum TransferStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  WHATSAPP_SENT
}

model PropertyTransfer {
  id           String         @id @default(cuid())
  propertyId   String
  property     Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  fromAgentId  String
  fromAgent    User           @relation("TransferFrom", fields: [fromAgentId], references: [id])
  toAgentId    String?
  toAgent      User?          @relation("TransferTo", fields: [toAgentId], references: [id])
  toAgentEmail String? // kept in case the target isn't registered yet
  status       TransferStatus @default(PENDING)
  message      String?
  createdAt    DateTime       @default(now())
  respondedAt  DateTime?

  @@index([fromAgentId])
  @@index([toAgentId])
  @@index([status])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([propertyId])
}

model PropertyVideo {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String // served via /uploads/videos/... or an external URL
  kind       String   @default("upload") // "upload" | "external" (youtube/vimeo)
  title      String?
  posterUrl  String?
  sizeBytes  Int?
  mimeType   String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([propertyId])
}

model MarketingAction {
  id         String    @id @default(cuid())
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  actionKey  String // e.g. "tabuExtract", "photography"…
  done       Boolean   @default(false)
  doneAt     DateTime?
  notes      String?
  link       String? // Listing URL (yad2/madlan/facebook) or any reference URL

  @@unique([propertyId, actionKey])
  @@index([propertyId])
}

model PropertyViewing {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  viewedAt   DateTime @default(now())
  source     String?
  notes      String?

  @@index([propertyId])
  @@index([leadId])
}

model PropertyInquiry {
  id           String   @id @default(cuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contactName  String
  contactPhone String?
  contactEmail String?
  message      String?
  createdAt    DateTime @default(now())

  @@index([propertyId])
}

model Lead {
  id                 String           @id @default(cuid())
  agentId            String
  agent              User             @relation("AgentLeads", fields: [agentId], references: [id])
  name               String
  phone              String
  email              String?
  interestType       LeadInterestType @default(PRIVATE)
  lookingFor         LeadLookingFor   @default(BUY)
  city               String?
  street             String?
  rooms              String?
  priceRangeLabel    String?
  budget             Int?
  preApproval        Boolean          @default(false)
  sector             String?
  balconyRequired    Boolean          @default(false)
  parkingRequired    Boolean          @default(false)
  elevatorRequired   Boolean          @default(false)
  safeRoomRequired   Boolean          @default(false)
  acRequired         Boolean          @default(false)
  storageRequired    Boolean          @default(false)
  schoolProximity    String?
  source             String?
  // `status` is the thermal temperature rating (HOT/WARM/COLD). New in
  // Sprint 1 / MLS parity Task K2: `customerStatus` is the separate
  // life-cycle flag (אקטואלי / לא אקטואלי / etc.). Kept orthogonal.
  status             LeadStatus       @default(WARM)
  notes              String?
  brokerageSignedAt  DateTime?
  brokerageExpiresAt DateTime?
  lastContact        DateTime?

  // Sprint 1 / MLS parity — Task K2. Customer admin block.
  customerStatus      CustomerStatus?
  commissionPct       Float?
  isPrivate           Boolean           @default(false)
  purposes            CustomerPurpose[] @default([])
  seriousnessOverride Seriousness?

  // Sprint 2 / MLS parity — Task K1. Richer contact + identity fields
  // mirroring the Nadlan customer form. Existing `name` / `phone` /
  // `email` stay as primary/display values; these are the expanded
  // variants so import/export and power-user flows don't lose data.
  firstName    String?
  lastName     String?
  companyName  String?
  address      String?
  cityText     String?
  zip          String?
  primaryPhone String?
  phone1       String?
  phone2       String?
  fax          String?
  personalId   String?
  // Sprint 2 / MLS parity — Task L3 placeholder. Quick-lead UI uses
  // the shorter single-line `description`; the longer `notes` stays.
  description  String?
  // Sprint 2 / MLS parity — Task L1. Quick-lead lifecycle status.
  leadStatus   QuickLeadStatus? @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  viewings        PropertyViewing[]
  customerProfile CustomerProfile?
  agreements      Agreement[]
  meetings        LeadMeeting[]
  reminders       Reminder[]
  // Sprint 1 / MLS parity — Task K2. Additional assignees. Primary
  // assignee stays `agentId` on Lead; the join table lets the office
  // share a lead across multiple agents.
  extraAgents     LeadAgent[]
  // Sprint 2 / MLS parity — Task K4. Repeatable "הנכס המבוקש" profiles.
  searchProfiles  LeadSearchProfile[]
  // Reverse of Prospect.lead — signed prospects linked to this lead.
  prospects       Prospect[]

  @@index([agentId])
  @@index([status])
  @@index([customerStatus])
  @@index([city])
}

// Sprint 1 / MLS parity — Task K2. Composite-PK join table for
// multi-agent lead assignment.
model LeadAgent {
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agentId    String
  agent      User     @relation("LeadAssignments", fields: [agentId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([leadId, agentId])
  @@index([agentId])
}

model Deal {
  id             String           @id @default(cuid())
  agentId        String
  agent          User             @relation("AgentDeals", fields: [agentId], references: [id])
  propertyId     String?          @unique
  property       Property?        @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  propertyStreet String
  city           String
  assetClass     AssetClass
  category       PropertyCategory
  status         DealStatus       @default(NEGOTIATING)
  marketingPrice Int
  offer          Int?
  closedPrice    Int?
  commission     Int?
  buyerAgent     String?
  sellerAgent    String?
  lawyer         String?
  updateDate     DateTime         @default(now())
  signedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([agentId])
  @@index([status])
}

model Agreement {
  id          String        @id @default(cuid())
  leadId      String?
  lead        Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  propertyId  String?
  property    Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  signerName  String
  signerPhone String?
  signerEmail String?
  fileId      String?
  file        UploadedFile? @relation(fields: [fileId], references: [id])
  sentAt      DateTime      @default(now())
  signedAt    DateTime?
  status      String        @default("SENT") // SENT | SIGNED | EXPIRED | CANCELLED
  note        String?

  @@index([leadId])
  @@index([propertyId])
}

model UploadedFile {
  id           String   @id @default(cuid())
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  kind         String // "property_image" | "signed_agreement" | "other"
  originalName String
  mimeType     String
  sizeBytes    Int
  path         String // relative path on disk inside /uploads
  createdAt    DateTime @default(now())

  agreements Agreement[]

  @@index([ownerId])
  @@index([kind])
}

enum MessageTemplateKind {
  BUY_PRIVATE // residential + sale
  RENT_PRIVATE // residential + rent
  BUY_COMMERCIAL // commercial + sale
  RENT_COMMERCIAL // commercial + rent
  TRANSFER // agent-to-agent handoff (no agent info)
}

model MessageTemplate {
  id        String              @id @default(cuid())
  agentId   String
  agent     User                @relation(fields: [agentId], references: [id], onDelete: Cascade)
  kind      MessageTemplateKind
  body      String
  updatedAt DateTime            @updatedAt

  @@unique([agentId, kind])
  @@index([agentId])
}

model CityLookup {
  name String @id
  lat  Float
  lng  Float
}

model StreetLookup {
  id   String @id @default(cuid())
  name String
  city String
  lat  Float
  lng  Float

  @@unique([name, city])
  @@index([city])
}

// 1.5 — Prospect intake form, per-property. Collected either in-person
// (canvas signature pad) or via a shareable short-lived public link
// (publicToken + tokenExpiresAt) that lands the prospect on a kiosk-
// style page they can sign on their own phone.
//
// Why a dedicated table instead of reusing Lead? A prospect is not
// necessarily a CRM-tracked customer — they might just be interested
// in this one property. Conversion "prospect → lead" is an explicit
// agent decision, not an auto-consequence of filling the form.
model Prospect {
  id               String    @id @default(cuid())
  propertyId       String
  property         Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agentId          String
  agent            User      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name             String
  phone            String?
  email            String?
  source           String?
  notes            String?
  // Data-URL of the rendered signature strokes. Small (a few KB PNG)
  // and self-contained — no extra storage backend required. Nullable
  // for the digital flow where the prospect signs later.
  signatureDataUrl String?
  signedAt         DateTime?
  // Identity fields captured on the public sign form (industry-standard
  // interested-party intake). Nullable because legacy rows pre-date these.
  idType           String?   // 'ID' (Israeli ת.ז.) | 'PASSPORT'
  idNumber         String?
  address          String?
  // Public sign-from-phone flow tokens.
  publicToken      String?   @unique
  tokenExpiresAt   DateTime?
  // Optional link to an existing Lead in the agent's CRM. Set either
  // by the auto-link heuristic on signing (exact-one phone/email
  // match under the same agent) or manually from PropertyDetail.
  leadId           String?
  lead             Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  // Per-agent sequential order number printed on the brokerage-services
  // agreement PDF. Back-filled for legacy rows by the migration.
  orderNumber      Int?
  createdAt        DateTime  @default(now())

  @@unique([agentId, orderNumber])
  @@index([propertyId])
  @@index([agentId])
  @@index([leadId])
}

// 7.2 — Meetings scheduled with a lead, optionally mirrored to the
// agent's Google Calendar. googleEventId ties the two so subsequent
// edits / deletes propagate.
model LeadMeeting {
  id            String   @id @default(cuid())
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agentId       String
  agent         User     @relation("AgentMeetings", fields: [agentId], references: [id], onDelete: Cascade)
  title         String
  notes         String?
  location      String?
  meetLink      String?
  startsAt      DateTime
  endsAt        DateTime
  googleEventId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([leadId])
  @@index([agentId])
  @@index([startsAt])
}

// ─── Tags ──────────────────────────────────────────────────────────────────
// Sprint 1 / MLS parity — Task A2. Nadlan calls these "מדבקות" (stickers /
// labels). A single `Tag` can target properties, leads, customers, or any
// mix (via `scope`). `TagAssignment` is a per-entity attach-point so we
// don't have to add a FK on every model. Join is manually-keyed rather
// than using a polymorphic column trick — keeps Prisma queries simple.
enum TagScope {
  PROPERTY
  LEAD
  CUSTOMER
  ALL
}

enum TagEntity {
  PROPERTY
  LEAD
  CUSTOMER
}

model Tag {
  id        String   @id @default(cuid())
  agentId   String
  agent     User     @relation("AgentTags", fields: [agentId], references: [id], onDelete: Cascade)
  name      String
  // Stored as a 7-char hex string (e.g. "#C9A14B"). No enum — callers
  // pick from the design-system palette client-side.
  color     String   @default("#C9A14B")
  scope     TagScope @default(ALL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments TagAssignment[]

  @@unique([agentId, name])
  @@index([agentId, scope])
}

model TagAssignment {
  id         String    @id @default(cuid())
  tagId      String
  tag        Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  entityType TagEntity
  entityId   String
  createdAt  DateTime  @default(now())

  @@unique([tagId, entityType, entityId])
  @@index([entityType, entityId])
}

// Sprint 1 / MLS parity — Task D1. Standalone reminder. The dashboard
// merges these with LeadMeetings for the "מתוכננות/ארכיון" panel.
model Reminder {
  id          String         @id @default(cuid())
  agentId     String
  agent       User           @relation("AgentReminders", fields: [agentId], references: [id], onDelete: Cascade)
  title       String
  notes       String?
  dueAt       DateTime
  status      ReminderStatus @default(PENDING)
  completedAt DateTime?
  cancelledAt DateTime?

  leadId     String?
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  // A `customerId` here is a User id (the customer-side login). Most
  // reminders anchor to a lead instead; this is for the rarer case of a
  // reminder tied to a confirmed customer.
  customerId String?
  customer   User?     @relation("ReminderCustomer", fields: [customerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId, status, dueAt])
  @@index([leadId])
  @@index([propertyId])
  @@index([customerId])
}

// Sprint 7 / MLS parity — Task G1. Canonical city+neighborhood
// lookup. Properties keep storing the free-text `neighborhood` column
// for back-compat; this table is the dictionary that powers
// autocomplete and hygiene. Aliases capture historical spellings
// (e.g. רמת-אביב vs רמת אביב) without a migration per variant.
model Neighborhood {
  id        String   @id @default(cuid())
  city      String
  name      String
  aliases   String[] @default([])
  createdAt DateTime @default(now())

  // Sprint 7 / MLS parity — Task G2. Reverse relation so cascading
  // deletes on a Neighborhood clean up the join rows automatically.
  groupMemberships NeighborhoodGroupMember[]

  @@unique([city, name])
  @@index([city])
}

// Sprint 7 / MLS parity — Task G2. Marketable-area grouping over the
// flat G1 dictionary. Nadlan One surfaces umbrella areas (e.g.
// "צפון ישן תל אביב") that agents actually discuss in person, and
// those groupings don't live in any OSM-style source. OWNERs curate
// them manually; agents consume them read-only.
model NeighborhoodGroup {
  id          String                    @id @default(cuid())
  city        String
  name        String
  description String?
  aliases     String[]                  @default([])
  members     NeighborhoodGroupMember[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@unique([city, name])
  @@index([city])
}

model NeighborhoodGroupMember {
  groupId        String
  neighborhoodId String
  sortOrder      Int               @default(0)
  group          NeighborhoodGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  neighborhood   Neighborhood      @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)

  @@id([groupId, neighborhoodId])
  @@index([neighborhoodId])
}

// Sprint 7 / MLS parity — Task B3. Named filter snapshots.
enum SavedSearchEntity {
  PROPERTY
  LEAD
}

model SavedSearch {
  id         String            @id @default(cuid())
  agentId    String
  agent      User              @relation("AgentSavedSearches", fields: [agentId], references: [id], onDelete: Cascade)
  entityType SavedSearchEntity
  name       String
  filters    Json
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([agentId])
}

// Sprint 7 / MLS parity — Task B4. Cross-entity pinboard.
enum FavoriteEntity {
  PROPERTY
  LEAD
  OWNER
}

model Favorite {
  id         String         @id @default(cuid())
  agentId    String
  agent      User           @relation("AgentFavorites", fields: [agentId], references: [id], onDelete: Cascade)
  entityType FavoriteEntity
  entityId   String
  createdAt  DateTime       @default(now())

  @@unique([agentId, entityType, entityId])
}

// Sprint 6 / MLS parity — Task F1. Per-channel marketing advert
// ("פרסום") for a property. MarketingAction tracks which channels
// have been touched; Advert tracks what copy was pushed to each
// channel (Yad2/Facebook/Onmap…) so agents can tweak titles and
// prices independently per outlet.
enum AdvertChannel {
  YAD2
  ONMAP
  MADLAN
  FACEBOOK
  WHATSAPP
  INSTAGRAM
  WEBSITE
  OTHER
}

enum AdvertStatus {
  DRAFT
  PUBLISHED
  PAUSED
  EXPIRED
  REMOVED
}

model Advert {
  id             String        @id @default(cuid())
  agentId        String
  agent          User          @relation("AgentAdverts", fields: [agentId], references: [id], onDelete: Cascade)
  propertyId     String
  property       Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  channel        AdvertChannel
  status         AdvertStatus  @default(DRAFT)
  title          String?
  body           String?
  publishedPrice Int?
  externalUrl    String?
  externalId     String?
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([agentId])
  @@index([propertyId])
  @@index([channel, status])
}

// Sprint 5 / MLS parity — Task J10. Secondary assignees on a
// property. `agentId` on Property stays the canonical owner (used
// for scoping); this join table lets additional agents collaborate.
model PropertyAssignee {
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("PropertyAssigneeUser", fields: [userId], references: [id], onDelete: Cascade)
  role       String   @default("CO_AGENT")
  assignedAt DateTime @default(now())

  @@id([propertyId, userId])
  @@index([userId])
}

// Sprint 5 / MLS parity — Task H3. Agent-scoped activity log. Records
// who did what to which entity so the UI can render a recent-activity
// timeline and office owners can audit their agents' moves. FKs are
// deliberately weak (no onDelete) — the log should outlive row
// deletion for audit purposes.
model ActivityLog {
  id         String   @id @default(cuid())
  agentId    String
  actorId    String?
  verb       String
  entityType String
  entityId   String?
  summary    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([entityType, entityId])
}

// Sprint 2 / MLS parity — Task K4. Repeatable "הנכס המבוקש" profile on
// a lead. A lead can have multiple profiles (e.g. one for a residence
// in Tel Aviv, another for an investment in Haifa) so matching hits
// all of them. The flat single-value criteria fields on Lead
// (`rooms`, `budget`, `city`, `sector`, the *Required booleans) stay
// for back-compat during rollout.
model LeadSearchProfile {
  id             String            @id @default(cuid())
  leadId         String
  lead           Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  // Optional user-facing label like "השקעה בתל אביב".
  label          String?
  domain         AssetClass?
  dealType       PropertyCategory?
  // PG text arrays keep the form wiring simple; frontend sends each as
  // a multi-select and backend stores without extra join tables.
  propertyTypes  String[]          @default([])
  cities         String[]          @default([])
  neighborhoods  String[]          @default([])
  streets        String[]          @default([])
  minRoom        Float?
  maxRoom        Float?
  minPrice       Int?
  maxPrice       Int?
  minPricePerSqm Int?
  maxPricePerSqm Int?
  minFloor       Int?
  maxFloor       Int?
  minBuilt       Int?
  maxBuilt       Int?
  minPlot        Int?
  maxPlot        Int?
  parkingReq     Boolean           @default(false)
  elevatorReq    Boolean           @default(false)
  balconyReq     Boolean           @default(false)
  furnitureReq   Boolean           @default(false)
  mamadReq       Boolean           @default(false)
  storeroomReq   Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([leadId])
}

// Market-context snapshot fetched from nadlan.gov.il (purchase or
// rent). Keyed by (cityKey, streetKey, kind) so multiple properties on
// the same street share one cache row. 24h TTL is enforced in the
// service layer, not the DB.
model MarketContext {
  id         String   @id @default(cuid())
  cityKey    String
  streetKey  String
  kind       String   // 'buy' | 'rent'
  fetchedAt  DateTime @default(now())
  dealCount  Int      @default(0)
  payload    Json
  error      String?

  @@unique([cityKey, streetKey, kind])
  @@index([fetchedAt])
}
