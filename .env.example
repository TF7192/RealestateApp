# Estia — environment variables (NO secrets — copy to .env locally and fill in)
# Production values live on the server in /home/ec2-user/estia-new/.env (chmod 600).

# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PUBLIC_ORIGIN=https://estia.tripzio.xyz

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=estia
POSTGRES_PASSWORD=                # set a long random string in prod
POSTGRES_DB=estia

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=                       # 64+ chars, generate with: openssl rand -hex 64

# ── Uploads (set to s3 in prod, local in dev) ───────────────────────────────
UPLOADS_BACKEND=local             # one of: local | s3
S3_BUCKET=estia-prod
S3_REGION=eu-north-1
# When UPLOADS_BACKEND=s3 the backend uses these. On EC2 prefer the IAM role
# attached to the instance (estia-prod-app) and leave both keys empty.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Docker port bindings ────────────────────────────────────────────────────
BACKEND_PORT=6002
BACKEND_BIND_ADDR=127.0.0.1
FRONTEND_PORT=3001
